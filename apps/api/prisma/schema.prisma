generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
  super_admin
}

enum UserStatus {
  invited
  pending
  active
  disabled
}

enum TagStatus {
  active
  hidden
  archived
}

enum EventStatus {
  draft
  published
  cancelled
  archived
}

enum EventFormat {
  online
  offline
  hybrid
}

enum EventVisibility {
  open
  approval_required
  invite_only
}

enum EventParticipantStatus {
  invited
  requested
  accepted
  declined
  banned
  attended
}

enum EventParticipantRole {
  attendee
  organizer
  manager
}

enum ReportTargetType {
  event
  tag
  user
}

enum ReportStatus {
  open
  reviewing
  resolved
  dismissed
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String
  passwordHash String     @map("password_hash")
  role         UserRole   @default(user)
  adminRoleGroupId String? @map("admin_role_group_id")
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  adminRoleGroup AdminRoleGroup? @relation(fields: [adminRoleGroupId], references: [id], onDelete: SetNull)
  createdTags  Tag[]   @relation("TagCreatedBy")
  updatedTags  Tag[]   @relation("TagUpdatedBy")
  createdEvents Event[] @relation("EventCreatedBy")
  updatedEvents Event[] @relation("EventUpdatedBy")
  eventParticipations EventParticipant[]
  interestTags UserInterestTag[]
  submittedReports ContentReport[] @relation("ReportSubmittedBy")
  resolvedReports ContentReport[] @relation("ReportResolvedBy")
  updatedReportGroupNotes ReportGroupNote[]

  @@map("users")
}

model AdminRoleGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  permissions String[] @default([])
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("admin_role_groups")
}

model CmsCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  faqs Faq[]

  @@index([status])
  @@map("cms_categories")
}

model Faq {
  id          String   @id @default(uuid())
  categoryId  String   @map("category_id")
  title       String
  body        String
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category CmsCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId, status])
  @@map("faqs")
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  body        String
  target      String   @default("all")
  status      String   @default("active")
  publishAt   DateTime @default(now()) @map("publish_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status, publishAt])
  @@map("announcements")
}

model CmsPolicy {
  id          String   @id @default(uuid())
  type        String   @unique
  title       String
  body        String
  status      String   @default("active")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("cms_policies")
}

model TagCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tags Tag[]

  @@map("tag_categories")
}

model Tag {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  status      TagStatus @default(active)
  usageCount  Int       @default(0) @map("usage_count")
  categoryId  String?   @map("category_id")
  createdById String?   @map("created_by")
  updatedById String?   @map("updated_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  category  TagCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy User?        @relation("TagCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?        @relation("TagUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  events    EventTag[]
  interestedUsers UserInterestTag[]

  @@index([status])
  @@map("tags")
}

model Event {
  id                      String      @id @default(uuid())
  title                   String
  slug                    String      @unique
  summary                 String
  description             String
  status                  EventStatus @default(published)
  startsAt                DateTime    @map("starts_at")
  endsAt                  DateTime?   @map("ends_at")
  timezone                String
  format                  EventFormat
  visibility              EventVisibility @default(open)
  locationName            String?     @map("location_name")
  locationAddress         String?     @map("location_address")
  city                    String?
  country                 String?
  latitude                Decimal?    @db.Decimal(10, 7)
  longitude               Decimal?    @db.Decimal(10, 7)
  language                String
  organizerName           String?     @map("organizer_name")
  externalRegistrationUrl String?     @map("external_registration_url")
  coverImageUrl           String?     @map("cover_image_url")
  capacity                Int?
  createdById             String?     @map("created_by")
  updatedById             String?     @map("updated_by")
  createdAt               DateTime    @default(now()) @map("created_at")
  updatedAt               DateTime    @updatedAt @map("updated_at")

  createdBy User?      @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?      @relation("EventUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  tags      EventTag[]
  participants EventParticipant[]
  media EventMedia[]

  @@index([status, startsAt])
  @@map("events")
}

model EventParticipant {
  id        String                 @id @default(uuid())
  eventId   String                 @map("event_id")
  userId    String                 @map("user_id")
  status    EventParticipantStatus @default(requested)
  role      EventParticipantRole   @default(attendee)
  checkedInAt DateTime?            @map("checked_in_at")
  createdAt DateTime               @default(now()) @map("created_at")
  updatedAt DateTime               @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId, status])
  @@map("event_participants")
}

model EventMedia {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  url       String
  type      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_media")
}

model EventTag {
  eventId String @map("event_id")
  tagId   String @map("tag_id")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([eventId, tagId])
  @@map("event_tags")
}

model UserInterestTag {
  userId    String   @map("user_id")
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([userId, tagId])
  @@index([tagId])
  @@map("user_interest_tags")
}

model ContentReport {
  id             String           @id @default(uuid())
  targetType     ReportTargetType @map("target_type")
  targetId       String           @map("target_id")
  ruleId         String?          @map("rule_id")
  reason         String
  details        String?
  status         ReportStatus     @default(open)
  resolutionNote String?          @map("resolution_note")
  reporterId     String           @map("reporter_id")
  resolvedById   String?          @map("resolved_by")
  resolvedAt     DateTime?        @map("resolved_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  reporter   User  @relation("ReportSubmittedBy", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy User? @relation("ReportResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  rule       ReportRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@index([status, createdAt])
  @@index([ruleId])
  @@map("content_reports")
}

model ReportGroupNote {
  id             String           @id @default(uuid())
  targetType     ReportTargetType @map("target_type")
  targetId       String           @map("target_id")
  note           String
  updatedById    String?          @map("updated_by")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  updatedBy User? @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([targetType, targetId])
  @@map("report_group_notes")
}

model ReportRule {
  id             String           @id @default(uuid())
  targetType     ReportTargetType @map("target_type")
  title          String
  description    String?
  violationScore Int              @default(1) @map("violation_score")
  status         String           @default("active")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  reports ContentReport[]

  @@index([targetType, status])
  @@map("report_rules")
}
