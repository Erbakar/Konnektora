generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
  super_admin
}

enum UserStatus {
  invited
  pending
  active
  disabled
  frozen
  deleted
  suspended
  banned
}

enum TagStatus {
  active
  hidden
  archived
}

enum EventStatus {
  draft
  published
  cancelled
  archived
}

enum EventFormat {
  online
  offline
  hybrid
}

enum EventVisibility {
  open
  approval_required
  invite_only
}

enum EventParticipantStatus {
  invited
  requested
  accepted
  declined
  banned
  attended
}

enum EventParticipantRole {
  attendee
  organizer
  manager
}

enum ReportTargetType {
  event
  tag
  user
  media
  place
  username
  website_url
  tag_comment
  event_comment
  place_comment
  comment_reply
  private_message
}

enum ReportStatus {
  open
  reviewing
  resolved
  dismissed
}

enum UserMessageType {
  faq
  account_freeze
  write_to_us
}

enum UserMessageStatus {
  unread
  read
}

enum CmsCategoryType {
  faq
  write_to_us
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String
  username     String?    @unique
  passwordHash String     @map("password_hash")
  role         UserRole   @default(user)
  adminRoleGroupId String? @map("admin_role_group_id")
  status       UserStatus @default(active)
  accountType  String     @default("individual") @map("account_type")
  phone        String?
  country      String?
  city         String?
  district     String?
  address      String?
  gender       String?
  birthDate    DateTime?  @map("birth_date")
  website      String?
  companyName  String?    @map("company_name")
  tradeName    String?    @map("trade_name")
  companyType  String?    @map("company_type")
  businessCategory String? @map("business_category")
  followerCount Int       @default(0) @map("follower_count")
  followingCount Int      @default(0) @map("following_count")
  lastOnlineAt DateTime?  @map("last_online_at")
  emailVerified Boolean   @default(false) @map("email_verified")
  invitedById  String?    @map("invited_by")
  penaltyScoreLastYear Int @default(0) @map("penalty_score_last_year")
  penaltyScoreAllTime Int  @default(0) @map("penalty_score_all_time")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  adminRoleGroup AdminRoleGroup? @relation(fields: [adminRoleGroupId], references: [id], onDelete: SetNull)
  invitedBy User? @relation("UserInvites", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedUsers User[] @relation("UserInvites")
  createdTags  Tag[]   @relation("TagCreatedBy")
  updatedTags  Tag[]   @relation("TagUpdatedBy")
  createdEvents Event[] @relation("EventCreatedBy")
  updatedEvents Event[] @relation("EventUpdatedBy")
  eventParticipations EventParticipant[]
  interestTags UserInterestTag[]
  submittedReports ContentReport[] @relation("ReportSubmittedBy")
  resolvedReports ContentReport[] @relation("ReportResolvedBy")
  updatedReportGroupNotes ReportGroupNote[]
  moderationDecisions ModerationDecision[] @relation("ModerationDecisionUser")
  issuedModerationDecisions ModerationDecision[] @relation("ModerationDecisionActor")
  emailTokens EmailToken[]
  userMessages UserMessage[] @relation("UserMessageUser")
  readUserMessages UserMessage[] @relation("UserMessageReadBy")
  createdPlaces Place[] @relation("PlaceCreatedBy")
  updatedPlaces Place[] @relation("PlaceUpdatedBy")
  uploadedMedia MediaFile[] @relation("MediaUploadedBy")
  authoredComments ContentComment[] @relation("CommentAuthor")
  sentPrivateMessages PrivateMessage[] @relation("PrivateMessageSender")
  receivedPrivateMessages PrivateMessage[] @relation("PrivateMessageRecipient")
  contentReactions ContentReaction[]
  contentViews ContentView[]

  @@map("users")
  @@index([accountType, status])
  @@index([country, city])
  @@index([lastOnlineAt])
}

model AdminRoleGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  permissions String[] @default([])
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("admin_role_groups")
}

model CmsCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  type        CmsCategoryType @default(faq)
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  faqs Faq[]

  @@index([status])
  @@index([type, status])
  @@map("cms_categories")
}

model Faq {
  id          String   @id @default(uuid())
  categoryId  String   @map("category_id")
  title       String
  body        String
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category CmsCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId, status])
  @@map("faqs")
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  body        String
  target      String   @default("all")
  status      String   @default("active")
  publishAt   DateTime @default(now()) @map("publish_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status, publishAt])
  @@map("announcements")
}

model CmsPolicy {
  id          String   @id @default(uuid())
  type        String   @unique
  title       String
  body        String
  status      String   @default("active")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("cms_policies")
}

model TagCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tags Tag[]

  @@map("tag_categories")
}

model Tag {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  status      TagStatus @default(active)
  usageCount  Int       @default(0) @map("usage_count")
  categoryId  String?   @map("category_id")
  createdById String?   @map("created_by")
  updatedById String?   @map("updated_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  category  TagCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy User?        @relation("TagCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?        @relation("TagUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  events    EventTag[]
  interestedUsers UserInterestTag[]

  @@index([status])
  @@map("tags")
}

model Event {
  id                      String      @id @default(uuid())
  title                   String
  slug                    String      @unique
  summary                 String
  description             String
  status                  EventStatus @default(published)
  startsAt                DateTime    @map("starts_at")
  endsAt                  DateTime?   @map("ends_at")
  timezone                String
  format                  EventFormat
  visibility              EventVisibility @default(open)
  locationName            String?     @map("location_name")
  locationAddress         String?     @map("location_address")
  city                    String?
  country                 String?
  latitude                Decimal?    @db.Decimal(10, 7)
  longitude               Decimal?    @db.Decimal(10, 7)
  language                String
  organizerName           String?     @map("organizer_name")
  externalRegistrationUrl String?     @map("external_registration_url")
  coverImageUrl           String?     @map("cover_image_url")
  capacity                Int?
  createdById             String?     @map("created_by")
  updatedById             String?     @map("updated_by")
  createdAt               DateTime    @default(now()) @map("created_at")
  updatedAt               DateTime    @updatedAt @map("updated_at")

  createdBy User?      @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?      @relation("EventUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  tags      EventTag[]
  participants EventParticipant[]
  media EventMedia[]

  @@index([status, startsAt])
  @@map("events")
}

model EventParticipant {
  id        String                 @id @default(uuid())
  eventId   String                 @map("event_id")
  userId    String                 @map("user_id")
  status    EventParticipantStatus @default(requested)
  role      EventParticipantRole   @default(attendee)
  checkedInAt DateTime?            @map("checked_in_at")
  createdAt DateTime               @default(now()) @map("created_at")
  updatedAt DateTime               @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId, status])
  @@map("event_participants")
}

model EventMedia {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  url       String
  type      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_media")
}

model Place {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  status      String   @default("active")
  coverImageUrl String? @map("cover_image_url")
  country     String?
  city        String?
  address     String?
  followerCount Int    @default(0) @map("follower_count")
  inviteCount Int      @default(0) @map("invite_count")
  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User? @relation("PlaceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("PlaceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([country, city])
  @@map("places")
}

model MediaFile {
  id          String   @id @default(uuid())
  url         String
  type        String   @default("image")
  status      String   @default("active")
  contentType ReportTargetType @map("content_type")
  contentId   String   @map("content_id")
  uploadedById String? @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  uploadedBy User? @relation("MediaUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([contentType, contentId])
  @@index([status, createdAt])
  @@map("media_files")
}

model ContentComment {
  id          String   @id @default(uuid())
  targetType  ReportTargetType @map("target_type")
  targetId    String   @map("target_id")
  parentId    String?  @map("parent_id")
  authorId    String?  @map("author_id")
  body        String
  status      String   @default("active")
  likeCount   Int      @default(0) @map("like_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent ContentComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies ContentComment[] @relation("CommentReplies")
  author User? @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@index([parentId])
  @@index([status, createdAt])
  @@map("content_comments")
}

model PrivateMessage {
  id          String   @id @default(uuid())
  senderId    String?  @map("sender_id")
  recipientId String?  @map("recipient_id")
  body        String
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sender User? @relation("PrivateMessageSender", fields: [senderId], references: [id], onDelete: SetNull)
  recipient User? @relation("PrivateMessageRecipient", fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([senderId, recipientId])
  @@index([status, createdAt])
  @@map("private_messages")
}

model ContentReaction {
  id          String   @id @default(uuid())
  targetType  ReportTargetType @map("target_type")
  targetId    String   @map("target_id")
  userId      String   @map("user_id")
  reaction    String
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([targetType, targetId, userId, reaction])
  @@index([targetType, targetId])
  @@map("content_reactions")
}

model ContentView {
  id          String   @id @default(uuid())
  targetType  ReportTargetType @map("target_type")
  targetId    String   @map("target_id")
  userId      String?  @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@index([userId])
  @@map("content_views")
}

model EventTag {
  eventId String @map("event_id")
  tagId   String @map("tag_id")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([eventId, tagId])
  @@map("event_tags")
}

model UserInterestTag {
  userId    String   @map("user_id")
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([userId, tagId])
  @@index([tagId])
  @@map("user_interest_tags")
}

model ContentReport {
  id             String           @id @default(uuid())
  targetType     ReportTargetType @map("target_type")
  targetId       String           @map("target_id")
  ruleId         String?          @map("rule_id")
  reason         String
  details        String?
  status         ReportStatus     @default(open)
  resolutionNote String?          @map("resolution_note")
  reporterId     String           @map("reporter_id")
  resolvedById   String?          @map("resolved_by")
  resolvedAt     DateTime?        @map("resolved_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  reporter   User  @relation("ReportSubmittedBy", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy User? @relation("ReportResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  rule       ReportRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@index([status, createdAt])
  @@index([ruleId])
  @@map("content_reports")
}

model ReportGroupNote {
  id             String           @id @default(uuid())
  targetType     ReportTargetType @map("target_type")
  targetId       String           @map("target_id")
  note           String
  updatedById    String?          @map("updated_by")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  updatedBy User? @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([targetType, targetId])
  @@map("report_group_notes")
}

model ReportRule {
  id             String           @id @default(uuid())
  targetType     ReportTargetType @map("target_type")
  title          String
  description    String?
  violationScore Int              @default(1) @map("violation_score")
  status         String           @default("active")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  reports ContentReport[]

  @@index([targetType, status])
  @@map("report_rules")
}

model ModerationDecision {
  id               String           @id @default(uuid())
  targetType       ReportTargetType @map("target_type")
  targetId         String           @map("target_id")
  decision         String
  action           String
  penaltyScore     Int              @default(0) @map("penalty_score")
  note             String?
  userId           String?          @map("user_id")
  issuedById       String?          @map("issued_by")
  suspensionEndsAt DateTime?        @map("suspension_ends_at")
  createdAt        DateTime         @default(now()) @map("created_at")

  user     User? @relation("ModerationDecisionUser", fields: [userId], references: [id], onDelete: SetNull)
  issuedBy User? @relation("ModerationDecisionActor", fields: [issuedById], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@index([userId])
  @@map("moderation_decisions")
}

model EmailToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  type       String
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
  @@map("email_tokens")
}

model UserMessage {
  id          String            @id @default(uuid())
  type        UserMessageType
  category    String?
  userId      String?           @map("user_id")
  name        String
  email       String
  phone       String?
  body        String
  status      UserMessageStatus @default(unread)
  appVersion  String?           @map("app_version")
  systemInfo  String?           @map("system_info")
  readAt      DateTime?         @map("read_at")
  readById    String?           @map("read_by")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  user   User? @relation("UserMessageUser", fields: [userId], references: [id], onDelete: SetNull)
  readBy User? @relation("UserMessageReadBy", fields: [readById], references: [id], onDelete: SetNull)

  @@index([type, status, createdAt])
  @@index([email])
  @@index([userId])
  @@map("user_messages")
}
